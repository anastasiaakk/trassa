{
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "main": "electron.js",
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/onest": "^5.2.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.5.0",
    "typescript": "^5.8.3",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.13.5",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^26.5.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "kill-port": "^2.0.1",
    "playwright": "^1.60.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.2"
  },
  "build": {
    "appId": "com.myapp.id",
    "productName": "Трасса",
    "directories": {
      "output": "packaged-app"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "electron.js",
      "preload.js",
      "package.json",
      "electron-assets/icon.png",
      "electron-assets/icon.ico",
      "electron-assets/update.json",
      "electron-assets/api.json",
      "electron-update-check.cjs"
    ],
    "extraResources": [
      {
        "from": "server/dist",
        "to": "trassa-api/dist"
      },
      {
        "from": "server/package.json",
        "to": "trassa-api/package.json"
      },
      {
        "from": "server/node_modules",
        "to": "trassa-api/node_modules"
      }
    ],
    "win": {
      "target": "dir",
      "icon": "electron-assets/icon.ico",
      "signAndEditExecutable": false
    }
  },
  "eslintConfig": {
    "root": true
  },
  "name": "trassa-app",
  "private": true,
  "scripts": {
    "assets:tagjs": "node scripts/sync-tagjs-assets.cjs",
    "assets:profile-avatars": "node scripts/extract-profile-avatar-sprites.cjs",
    "dev": "node scripts/sync-tagjs-assets.cjs && vite",
    "build": "node scripts/sync-tagjs-assets.cjs && tsc && vite build",
    "build:web": "node scripts/sync-tagjs-assets.cjs && tsc && vite build --mode web",
    "optimize:entry-splash": "node scripts/optimize-entry-splash-video.cjs",
    "deploy:web": "python scripts/deploy-portal-web.py",
    "deploy:api": "python scripts/remote-deploy-api-update.py",
    "deploy:sync": "python scripts/deploy-sync-all.py",
    "sync:page2-css": "node scripts/extract-page2-css-from-prod.cjs",
    "design:pin": "node scripts/save-my-design-snapshot.cjs",
    "design:restore-pin": "node scripts/restore-portal-design.cjs my-design",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "smoke:portal": "node scripts/smoke-portal.mjs",
    "smoke:portal:web": "node scripts/smoke-portal-web.mjs",
    "capture:presentation-devices": "node scripts/capture-presentation-devices.mjs",
    "record:mobile-demo": "node scripts/record-mobile-demo.mjs",
    "record:mobile-instruction": "node scripts/record-mobile-instruction.mjs",
    "narrate:mobile-instruction": "node scripts/mux-instruction-narration.mjs",
    "preview": "vite preview",
    "start": "vite",
    "electron:dev": "electron .",
    "server:proddeps": "node scripts/server-proddeps.cjs",
    "server:restoredeps": "npm install --prefix server",
    "icons:ico": "node scripts/generate-icon-ico.cjs",
    "release:prune": "node scripts/prune-release.cjs",
    "electron:build": "node scripts/sync-tagjs-assets.cjs && node scripts/ensure-public-assets.cjs && node scripts/generate-icon-ico.cjs && node scripts/apply-release-config.cjs --installer && tsc && vite build && npm run server:restoredeps && npm run build --prefix server && npm run server:proddeps && node scripts/clean-release-win-unpacked.cjs && electron-builder --win dir --publish never && node scripts/embed-win-icon.cjs && node scripts/build-neo-setup.cjs && node scripts/sync-setup-download.cjs && npm run server:restoredeps",
    "release:config": "node scripts/apply-release-config.cjs",
    "dist": "electron-builder",
    "server:dev": "npm run dev --prefix server",
    "server:install": "npm install --prefix server",
    "dev:all": "concurrently -k \"npm run server:dev\" \"npm run dev\""
  },
  "version": "0.2.18"
}
