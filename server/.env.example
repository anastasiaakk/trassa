# Скопируйте в .env и задайте свои значения.
# JWT_SECRET — случайная строка ≥32 символов (например: openssl rand -hex 32)

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
PORT=4000
# По умолчанию API слушает только 127.0.0.1 (безопасно). За nginx на том же сервере — так и оставьте.
# Прямой доступ к Node из интернета (без nginx): LISTEN_HOST=0.0.0.0
# LISTEN_HOST=127.0.0.1

# Через запятую. Для публичного сайта добавьте origin фронта, например:
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://trassa.ru,https://www.trassa.ru
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# За reverse-proxy (nginx / TLS): включите, чтобы корректно работали IP и rate limit
# TRUST_PROXY=1

# Доступ к порталу только из России (по IP). В production включено по умолчанию.
# PORTAL_REGION_GATE=0 — отключить гео-ограничение

# Лимиты /api/auth за 15 минут с одного IP (нужен TRUST_PROXY за nginx)
# AUTH_REGISTER_RATE_LIMIT_MAX=30
# AUTH_LOGIN_RATE_LIMIT_MAX=40
# AUTH_SESSION_RATE_LIMIT_MAX=400

# Только POST /api/admin/login (дашборд /api/admin/stats лимит не тратит)
# ADMIN_LOGIN_RATE_LIMIT_MAX=40

# ИИ: Т-бот в кабинете + админка «Таблицы»
#
# --- OpenRouter (рекомендуем: бесплатно, мощно, из РФ) ---
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_TBOT_MODEL=meta-llama/llama-3.3-70b-instruct:free
# TBOT_AI_MAX_TOKENS=512
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Лимит: ~50 запросов/день без пополнения; 20/мин. Карта не нужна.
#
# --- Google Gemini (бесплатно, умный Flash) ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
#
# --- DeepSeek ---
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
#
# --- GigaChat (Сбер) ---
# AI_PROVIDER=gigachat
# GIGACHAT_AUTH_KEY=...   # Authorization Key из личного кабинета developers.sber.ru
# GIGACHAT_MODEL=GigaChat-2-Pro
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_TLS_INSECURE=1   # по умолчанию 1 (сертификат Сбера в Node без российского CA)
#
# --- OpenAI (нужен ключ + из РФ часто прокси) ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1
# Исходящий прокси только для OpenAI (VPS в РФ → OpenAI блокирует IP без прокси):
# HTTP:  OPENAI_HTTPS_PROXY=http://user:pass@host:port
# SOCKS: OPENAI_HTTPS_PROXY=socks5://127.0.0.1:1080
# (на VPS: ssh -N -D 1080 user@us-server, затем socks5://127.0.0.1:1080)
# TBOT_RATE_LIMIT_MAX=80
# TBOT_AI_SYSTEM=опционально переопределить промпт Т-бота
# ADMIN_AI_SYSTEM=опционально переопределить промпт чата админки

# SMS при нарушениях портала (скриншот и т.п.) — опционально
# ADMIN_ALERT_PHONES=79001234567,79007654321
# SMSC_LOGIN=your_smsc_login
# SMSC_PASSWORD=your_smsc_password
# или свой webhook: SMS_WEBHOOK_URL=https://example.com/sms (JSON: { text, phones })
